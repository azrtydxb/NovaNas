# Dev image for @novanas/api — runs `tsx watch` for hot-reload.
# Source is bind-mounted by docker-compose; the install baked in here just
# seeds node_modules so the first start is fast.

FROM node:22-slim

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/schemas ./packages/schemas
COPY packages/db ./packages/db
COPY packages/api ./packages/api

RUN pnpm install --frozen-lockfile --filter @novanas/api...

EXPOSE 8080

CMD ["pnpm", "--filter", "@novanas/api", "dev"]
