{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "types": ["node"],
    "paths": {
      "@novanas/schemas": ["../schemas/dist/index.d.ts"],
      "@novanas/schemas/*": ["../schemas/dist/*"],
      "@novanas/db": ["../db/dist/index.d.ts"],
      "@novanas/db/*": ["../db/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "../schemas" }, { "path": "../db" }]
}
