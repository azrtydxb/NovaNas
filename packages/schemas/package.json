{
  "name": "@novanas/schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Zod schemas and inferred TypeScript types for NovaNas CRDs and API shapes.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "echo 'no tests yet' && exit 0"
  },
  "dependencies": {
    "zod": "~3.23.0"
  },
  "devDependencies": {
    "typescript": "~5.6.0"
  }
}
