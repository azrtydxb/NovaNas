{
  "realm": "novanas",
  "enabled": true,
  "displayName": "NovaNAS",
  "displayNameHtml": "NovaNAS Storage Control Plane",
  "accessTokenLifespan": 300,
  "refreshTokenLifespan": 1800,
  "revokeRefreshToken": true,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "refreshTokenMaxReuse": 0,
  "sslRequired": "all",
  "defaultSignatureAlgorithm": "RS256",
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 0,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "clients": [
    {
      "clientId": "nova-csi",
      "name": "NovaNAS CSI driver",
      "description": "Service account for the NovaNAS CSI driver (client_credentials grant).",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "use.refresh.tokens": "false",
        "client_credentials.use_refresh_token": "false"
      },
      "defaultClientScopes": ["roles"],
      "optionalClientScopes": []
    },
    {
      "clientId": "nova-api",
      "name": "NovaNAS API",
      "description": "NovaNAS storage API client",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [],
      "webOrigins": [],
      "protocol": "openid-connect",
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "accessType": "PUBLIC",
      "defaultClientScopes": ["profile", "email", "roles"],
      "optionalClientScopes": [],
      "useRefreshTokens": true,
      "requireRefreshTokenRotation": true,
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "nova-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "nova-admin",
        "description": "Full administrative access to NovaNAS",
        "composite": false,
        "clientRole": false,
        "containerId": "novanas"
      },
      {
        "name": "nova-operator",
        "description": "Operator access: manage pools, datasets, snapshots",
        "composite": false,
        "clientRole": false,
        "containerId": "novanas"
      },
      {
        "name": "nova-viewer",
        "description": "Read-only access to NovaNAS resources",
        "composite": false,
        "clientRole": false,
        "containerId": "novanas"
      },
      {
        "name": "nova-system-admin",
        "description": "System-level admin for bootstrap and recovery",
        "composite": false,
        "clientRole": false,
        "containerId": "novanas"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@novanas.local",
      "emailVerified": false,
      "enabled": true,
      "firstName": "NovaNAS",
      "lastName": "Administrator",
      "credentials": [
        {
          "type": "password",
          "value": "CHANGE_ME_ON_FIRST_LOGIN",
          "temporary": true
        }
      ],
      "realmRoles": ["nova-admin", "nova-system-admin"],
      "clientRoles": {}
    }
  ],
  "userFederationProviders": [],
  "userFederationMappers": [],
  "scopeMappings": [],
  "clientScopeMappings": {},
  "organizationsEnabled": false,
  "attributes": {
    "userProfileEnabled": "true"
  },
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":255},\"username-prohibited-characters\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]}},{\"name\":\"nova-tenant\",\"displayName\":\"NovaNAS tenant ID\",\"multivalued\":true,\"permissions\":{\"view\":[\"admin\"],\"edit\":[\"admin\"]},\"validations\":{\"length\":{\"min\":1,\"max\":63},\"pattern\":{\"pattern\":\"^[a-z0-9][a-z0-9-]{0,62}$\",\"error-message\":\"tenant id must be lowercase alphanumeric/hyphen, 1-63 chars\"}},\"annotations\":{\"description\":\"Scopes the user to a NovaNAS tenant. The Keycloak ↔ KDC sync daemon provisions a Kerberos principal '<username>/<tenant>@NOVANAS.LOCAL' for each value. Multi-valued: a user can belong to multiple tenants.\"}},{\"name\":\"nova-platform-nfs\",\"displayName\":\"Platform NFS access\",\"permissions\":{\"view\":[\"admin\"],\"edit\":[\"admin\"]},\"annotations\":{\"description\":\"Set to 'true' to provision a bare-username Kerberos principal for a platform-level (non-tenant) user. Ignored when nova-tenant is set.\"}}]}"
          ]
        }
      }
    ]
  },
  "keycloakVersion": "25.0.0"
}
