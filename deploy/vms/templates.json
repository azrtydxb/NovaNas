{
  "$schema": "https://novanas.example/schemas/vm-templates.v1.json",
  "version": 1,
  "templates": [
    {
      "id": "debian-12-cloud",
      "displayName": "Debian 12 (Bookworm) cloud",
      "os": "linux",
      "family": "debian",
      "version": "12",
      "arch": "amd64",
      "imageURL": "https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-amd64.qcow2",
      "imageFormat": "qcow2",
      "defaultCPU": 2,
      "defaultMemoryMB": 2048,
      "defaultDiskGB": 20,
      "cloudInitFriendly": true,
      "guestUser": "debian",
      "description": "Debian 12 generic cloud image. Cloud-init enabled."
    },
    {
      "id": "ubuntu-24.04-cloud",
      "displayName": "Ubuntu 24.04 LTS (Noble) cloud",
      "os": "linux",
      "family": "ubuntu",
      "version": "24.04",
      "arch": "amd64",
      "imageURL": "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img",
      "imageFormat": "qcow2",
      "defaultCPU": 2,
      "defaultMemoryMB": 2048,
      "defaultDiskGB": 20,
      "cloudInitFriendly": true,
      "guestUser": "ubuntu",
      "description": "Ubuntu 24.04 LTS server cloud image."
    },
    {
      "id": "fedora-40-cloud",
      "displayName": "Fedora 40 cloud",
      "os": "linux",
      "family": "fedora",
      "version": "40",
      "arch": "amd64",
      "imageURL": "https://download.fedoraproject.org/pub/fedora/linux/releases/40/Cloud/x86_64/images/Fedora-Cloud-Base-Generic.x86_64-40-1.14.qcow2",
      "imageFormat": "qcow2",
      "defaultCPU": 2,
      "defaultMemoryMB": 2048,
      "defaultDiskGB": 15,
      "cloudInitFriendly": true,
      "guestUser": "fedora",
      "description": "Fedora 40 generic cloud image."
    },
    {
      "id": "alma-9-cloud",
      "displayName": "AlmaLinux 9 cloud",
      "os": "linux",
      "family": "almalinux",
      "version": "9",
      "arch": "amd64",
      "imageURL": "https://repo.almalinux.org/almalinux/9/cloud/x86_64/images/AlmaLinux-9-GenericCloud-latest.x86_64.qcow2",
      "imageFormat": "qcow2",
      "defaultCPU": 2,
      "defaultMemoryMB": 2048,
      "defaultDiskGB": 15,
      "cloudInitFriendly": true,
      "guestUser": "almalinux",
      "description": "AlmaLinux 9 generic cloud image (RHEL-compatible)."
    },
    {
      "id": "windows-11",
      "displayName": "Windows 11 (BYO ISO)",
      "os": "windows",
      "family": "windows",
      "version": "11",
      "arch": "amd64",
      "imageURL": "",
      "imageFormat": "iso",
      "defaultCPU": 4,
      "defaultMemoryMB": 8192,
      "defaultDiskGB": 64,
      "cloudInitFriendly": false,
      "requiresUserSuppliedISO": true,
      "requiresLicenseKey": true,
      "description": "Placeholder. Microsoft does not redistribute Windows 11 cloud images. Operator must supply an ISO and a valid license key. See docs/vms/README.md."
    }
  ]
}
