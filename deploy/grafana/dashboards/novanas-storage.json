{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Prometheus --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "NovaNAS storage pool metrics: capacity, scrub state, vdev errors, fragmentation",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Total usable capacity of the storage pool",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "expr": "(node_filesystem_used_bytes{mountpoint=~\"/mnt/.*\",fstype=\"zfs\"} / node_filesystem_size_bytes{mountpoint=~\"/mnt/.*\",fstype=\"zfs\"}) * 100",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{ mountpoint }}",
          "refId": "A"
        }
      ],
      "title": "Pool Capacity Usage (%)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Free space remaining in storage pool",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 20
              }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=~\"/mnt/.*\",fstype=\"zfs\"}",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{ mountpoint }}",
          "refId": "A"
        }
      ],
      "title": "Free Space (Bytes)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "ZFS vdev error counts",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Errors",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "expr": "increase(node_zfs_vdev_errors_total[5m])",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{ vdev }}",
          "refId": "A"
        }
      ],
      "title": "ZFS vdev Errors (5m)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
