# The repo-root .gitignore excludes `build/` globally. In this package,
# `build/` contains source scripts that orchestrate image builds — the actual
# artifacts land under `build/out/`. Un-ignore the scripts, keep outputs
# ignored.
!build/
!build/*.sh
!build/*.txt
build/out/

# mkosi transient build context (legacy path, no longer used; postinst.chroot
# can't see /work/src so we switched to ExtraTrees).
mkosi.build-src/

# Installer binary is staged into mkosi.extra-live/ at build time so mkosi
# ExtraTrees copies it into the rootfs. Tracked layout (etc/, usr/, etc.)
# stays in git; the freshly-built Go binary is per-build.
mkosi.extra-live/usr/local/bin/novanas-installer

# Also un-ignore rootfs/usr/local/bin (was caught by `bin/` in root gitignore).
!rootfs/usr/local/bin/
!rootfs/usr/local/bin/*.sh

# Generated RAUC signing material (placeholder files are kept by name;
# developer-generated keys are not).
rauc/key.pem
rauc/*.signed.raucb
