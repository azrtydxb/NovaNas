# Installer ISO default: bring every wired Ethernet interface up so the
# TUI can show real link state (cable plugged / unplugged) when the
# operator is choosing the management NIC. Without this networkd ignores
# the interface entirely and it stays administratively DOWN, making
# every NIC look "link:down" regardless of cable.
#
# RequiredForOnline=no so a missing-cable interface doesn't block
# network-online.target during boot.
[Match]
Name=en*

[Link]
RequiredForOnline=no

[Network]
DHCP=yes
IPv6AcceptRA=yes
