# Stray Go-era build outputs (binaries that the deleted Go cmd/ tree
# used to produce). The Rust storage/meta crate lives at the same
# path, so be careful not to ignore the directory; only ignore the
# bare-name binaries we know about by name.
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test
cover.out
coverage.out
coverage.html
*.test

# Build dependencies
/bin/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Go
vendor/

# Protobuf generated
internal/proto/gen/

# Documentation build
site/

# Kubernetes
kubeconfig
*.kubeconfig

# Secrets (never commit)
.env
.env.*
*.pem
*.key
credentials.json

# Worktrees
.worktrees/
dataplane/nvmeof-tcp/target/
